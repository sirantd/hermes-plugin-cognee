+
+    def test_does_not_set_embedding_vars_without_gemini_key(self, monkeypatch, staged_cognee):
+        monkeypatch.setenv("LLM_PROVIDER", "deepseek")
+        monkeypatch.setenv("LLM_API_KEY", "sk-test")
